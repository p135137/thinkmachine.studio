<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>SAMURAI SHOWDOWN</title>
<style>
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0; width: 100%; height: 100%;
    background: #0c0810;
    font-family: 'Courier New', monospace;
    overflow: hidden;
    user-select: none;
  }
  #wrap {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: 100%; height: 100%;
    padding: 12px;
  }
  #title {
    color: #ffffff;
    text-shadow: 3px 3px 0 #9a1f3d, -1px -1px 0 #4a0e1f;
    font-size: clamp(20px, 4vw, 34px);
    letter-spacing: 6px;
    margin: 0 0 8px 0;
    font-weight: bold;
  }
  #subtitle {
    color: #d98aa8;
    font-size: 11px;
    letter-spacing: 3px;
    margin-bottom: 10px;
    opacity: 0.85;
  }
  #stage {
    position: relative;
    border: 4px solid #9a1f3d;
    box-shadow: 0 0 0 4px #1a1015, 0 0 30px rgba(200,40,80,0.35), inset 0 0 40px rgba(0,0,0,0.3);
    border-radius: 4px;
    background: #fff0f4;
    max-width: 100%;
  }
  canvas {
    display: block;
    image-rendering: pixelated;
    width: 100%;
    max-width: 800px;
    height: auto;
  }
  #scanlines {
    pointer-events: none;
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      rgba(0,0,0,0.06) 0px,
      rgba(0,0,0,0.06) 1px,
      rgba(0,0,0,0) 2px,
      rgba(0,0,0,0) 3px
    );
    mix-blend-mode: multiply;
  }
  #vignette {
    pointer-events: none;
    position: absolute; inset: 0;
    box-shadow: inset 0 0 80px 20px rgba(150,30,60,0.15);
  }
  #controls {
    margin-top: 12px;
    color: #cba3b3;
    font-size: 11px;
    letter-spacing: 1px;
    text-align: center;
    line-height: 1.6;
  }
  #controls b { color: #ff6b93; }
</style>
</head>
<body>
<div id="wrap">
  <div id="title">桜 SAMURAI SHOWDOWN 桜</div>
  <div id="subtitle">— A RONIN'S LAST STAND —</div>
  <div id="stage">
    <canvas id="game" width="800" height="420"></canvas>
    <div id="scanlines"></div>
    <div id="vignette"></div>
  </div>
  <div id="controls">
    <b>&larr; &rarr;</b> or <b>A / D</b> move / select &nbsp;|&nbsp; <b>&uarr; / W / SPACE</b> jump (double jump!) &nbsp;|&nbsp; <b>J / F / CLICK</b> slash &nbsp;|&nbsp; <b>ENTER</b> confirm / start / restart
  </div>
</div>

<script>
(() => {
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');
const W = canvas.width, H = canvas.height;
const GROUND_Y = H - 70;

// ---------- Audio ----------
let actx = null;
function ensureAudio() {
  if (!actx) actx = new (window.AudioContext || window.webkitAudioContext)();
}
function beep(freq, dur, type='square', vol=0.12, delay=0) {
  if (!actx) return;
  const t0 = actx.currentTime + delay;
  const osc = actx.createOscillator();
  const gain = actx.createGain();
  osc.type = type;
  osc.frequency.setValueAtTime(freq, t0);
  gain.gain.setValueAtTime(vol, t0);
  gain.gain.exponentialRampToValueAtTime(0.001, t0 + dur);
  osc.connect(gain).connect(actx.destination);
  osc.start(t0);
  osc.stop(t0 + dur + 0.02);
}
function sfxSlash() { beep(620, 0.06, 'square', 0.10); beep(880, 0.05, 'square', 0.08, 0.03); }
function sfxJump() { beep(300, 0.1, 'triangle', 0.10); beep(500, 0.08, 'triangle', 0.08, 0.05); }
function sfxDeathEnemy() { beep(200, 0.08, 'square', 0.12); beep(80, 0.18, 'square', 0.12, 0.05); }
function sfxGameOver() { beep(300, 0.2, 'sawtooth', 0.15); beep(200, 0.2, 'sawtooth', 0.15, 0.18); beep(100, 0.4, 'sawtooth', 0.15, 0.36); }
function sfxLevelUp() { beep(500, 0.08, 'square', 0.12); beep(650, 0.08, 'square', 0.12, 0.08); beep(900, 0.14, 'square', 0.12, 0.16); }
function sfxHurt() { beep(150, 0.12, 'sawtooth', 0.16); }
function sfxSelect() { beep(440, 0.05, 'square', 0.08); }
function sfxConfirm() { beep(500, 0.06, 'square', 0.10); beep(750, 0.08, 'square', 0.10, 0.05); }
function sfxThud() { beep(180, 0.08, 'triangle', 0.12); }
function sfxPowerup() { beep(700, 0.06, 'square', 0.10); beep(1000, 0.08, 'square', 0.10, 0.06); beep(1300, 0.1, 'square', 0.10, 0.12); }

// ---------- Palette: light cherry-blossom theme (the game window itself) ----------
const PAL = {
  skyTop: '#fdeef4',
  skyBot: '#ffc9dd',
  sun: '#fff3c2',
  sunGlow: 'rgba(255, 214, 160, 0.35)',
  mountainFar: '#e3b8cc',
  mountainNear: '#d191ab',
  ground: '#f7e2ea',
  groundDirt: '#f0cfdd',
  groundLine: '#e28bab',
  bladeColor: '#f0f0f5',
  hudText: '#c9457a',
  hudShadow: '#ffffff',
  platform: '#c98a63',
  platformTop: '#e8b088',
  dummyPost: '#7a5638',
  dummyStraw: '#e0c078',
  dummyStrawDark: '#c9a058',
  dummyArm: '#5a3d26',
  petalColors: ['#ffb7ce','#ff8fab','#ffe0ec']
};

// ---------- Character roster: distinct silhouettes, not just recolors ----------
const CHARACTERS = [
  { type: 'kasa',   gi: '#c0435f', giDark: '#833048', skin: '#e8c39e', hair: '#2a1810', hatColor: '#e0c78a', hatDark: '#c9a058' },
  { type: 'kabuto', gi: '#5a7fc4', giDark: '#3a5590', skin: '#e8c39e', hair: '#1a1a2a', accent: '#243a63', accent2: '#d9a441' },
  { type: 'dual',   gi: '#d9a441', giDark: '#a67722', skin: '#e8c39e', hair: '#2a1a10', accent: '#c0435f' },
  { type: 'spear',  gi: '#5fa88a', giDark: '#3a7860', skin: '#e8c39e', hair: '#101010', accent: '#2a4a3a' },
  { type: 'hood',   gi: '#9a6fb0', giDark: '#6a4a80', skin: '#e8c39e', hair: '#1a1a1a', accent: '#4a3a5a', accent2: '#ffd1dc' }
];
let selCursor = 0;
let selNavCooldown = 0;

// ---------- Input ----------
const keys = {};
window.addEventListener('keydown', e => {
  keys[e.code] = true;
  if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Space','Enter'].includes(e.code)) e.preventDefault();
  ensureAudio();
  if (e.code === 'Enter') handleConfirm();
});
window.addEventListener('keyup', e => keys[e.code] = false);

const stageEl = document.getElementById('stage');
function stagePressStart(e) {
  e.preventDefault();
  ensureAudio();
  if (state === 'playing') {
    keys['KeyJ'] = true;
  } else {
    handleConfirm();
  }
}
function stagePressEnd(e) {
  e.preventDefault();
  keys['KeyJ'] = false;
}
stageEl.addEventListener('mousedown', stagePressStart);
stageEl.addEventListener('mouseup', stagePressEnd);
stageEl.addEventListener('mouseleave', stagePressEnd);
stageEl.addEventListener('touchstart', stagePressStart);
stageEl.addEventListener('touchend', stagePressEnd);
stageEl.addEventListener('touchcancel', stagePressEnd);

// ---------- Game state ----------
let state = 'select'; // select, playing, gameover
let score = 0;
let hiScore = 0;
let lives = 3;
let wave = 1;
let frame = 0;
let shake = 0;
let particles = [];
let bgOffset = 0;
let scrollSpeed = 1.6;

const player = {
  x: 120, y: GROUND_Y, w: 34, h: 58,
  vx: 0, vy: 0,
  onGround: true,
  facing: 1,
  slashing: 0,
  slashCooldown: 0,
  hurtTimer: 0,
  invuln: 0,
  jumping: false,
  speedTimer: 0,
  shieldTimer: 0,
  jumpsUsed: 0,
  prevJumpKey: false
};

let enemies = [];
let platforms = [];
let obstacles = [];
let powerups = [];
let spawnTimer = 0;
let spawnInterval = 100;
let platformTimer = 0;
let obstacleTimer = 0;

const POWERUP_TYPES = ['heart', 'shield', 'speed'];

// ---------- Decorative background: trees + falling petals (always animate) ----------
const bgTrees = [
  { xr: 0.06, scale: 1.0, layer: 'near' },
  { xr: 0.90, scale: 1.15, layer: 'near' },
  { xr: 0.32, scale: 0.7, layer: 'far' },
  { xr: 0.68, scale: 0.8, layer: 'far' }
];
let petals = [];
for (let i = 0; i < 26; i++) {
  petals.push({
    x: Math.random() * W,
    y: Math.random() * H,
    s: 3 + Math.random() * 4,
    vy: 0.4 + Math.random() * 0.6,
    drift: Math.random() * Math.PI * 2,
    driftSpeed: 0.01 + Math.random() * 0.02,
    color: PAL.petalColors[Math.floor(Math.random() * PAL.petalColors.length)]
  });
}

function resetGame() {
  score = 0;
  lives = 3;
  wave = 1;
  scrollSpeed = 1.6;
  spawnInterval = 100;
  enemies = [];
  platforms = [];
  obstacles = [];
  powerups = [];
  particles = [];
  player.x = 120; player.y = GROUND_Y; player.vx = 0; player.vy = 0;
  player.onGround = true; player.facing = 1; player.slashing = 0; player.slashCooldown = 0;
  player.hurtTimer = 0; player.invuln = 90;
  player.speedTimer = 0; player.shieldTimer = 0;
  player.jumpsUsed = 0; player.prevJumpKey = false;
  spawnTimer = 40;
  platformTimer = 90;
  obstacleTimer = 150;
}

function handleConfirm() {
  if (state === 'select') {
    sfxConfirm();
    resetGame();
    state = 'playing';
  } else if (state === 'gameover') {
    state = 'select';
    sfxSelect();
  }
}

// ---------- Spawning ----------
function spawnEnemy() {
  // Enemies only start attacking from the left in later waves.
  const leftChance = wave <= 2 ? 0 : Math.min(0.5, (wave - 2) * 0.15);
  const fromRight = Math.random() >= leftChance;
  const speed = 1.1 + Math.min(wave * 0.15, 2.2) + Math.random() * 0.4;
  enemies.push({
    x: fromRight ? W + 40 : -40,
    y: GROUND_Y,
    w: 30, h: 54,
    vy: 0,
    onGround: true,
    vx: fromRight ? -speed : speed,
    dir: fromRight ? -1 : 1,
    dead: false,
    deathTimer: 0,
    hitFlash: 0,
    bob: Math.random() * Math.PI * 2,
    jumpCooldown: 30 + Math.random() * 60
  });
}

function spawnPlatform() {
  const h = 14;
  const restY = GROUND_Y - (60 + Math.random() * 140);
  const w = 90 + Math.random() * 70;
  const pf = { x: W + 60, y: restY, restY, w, h };
  platforms.push(pf);

  // Power-ups start appearing on platforms as difficulty increases.
  if (wave >= 2) {
    const chance = Math.min(0.5, 0.12 + (wave - 1) * 0.06);
    if (powerups.length < 2 && Math.random() < chance) {
      const type = POWERUP_TYPES[Math.floor(Math.random() * POWERUP_TYPES.length)];
      powerups.push({ x: pf.x + pf.w / 2 - 10, y: pf.restY - 22, w: 20, h: 20, type });
    }
  }
}

function spawnObstacle() {
  const w = 24;
  const h = 34;
  obstacles.push({ x: W + 40, y: GROUND_Y, w, h });
}

// ---------- Generic vertical physics (used by player + enemies) ----------
function applyGravityAndPlatforms(entity) {
  const prevY = entity.y;
  entity.vy += 0.65;
  entity.y += entity.vy;
  entity.onGround = false;
  for (const pf of platforms) {
    if (entity.x + entity.w > pf.x && entity.x < pf.x + pf.w) {
      if (entity.vy >= 0 && prevY <= pf.restY && entity.y >= pf.restY) {
        entity.y = pf.restY;
        entity.vy = 0;
        entity.onGround = true;
      }
    }
  }
  if (entity.y >= GROUND_Y) {
    entity.y = GROUND_Y;
    entity.vy = 0;
    entity.onGround = true;
  }
}

function updateVertical(entity, wantJump, jumpVel = -12.5) {
  if (wantJump && entity.onGround) {
    entity.vy = jumpVel;
    entity.onGround = false;
  }
  applyGravityAndPlatforms(entity);
}

// ---------- Update ----------
function update() {
  frame++;
  if (shake > 0) shake--;

  petals.forEach(p => {
    p.drift += p.driftSpeed;
    p.y += p.vy + Math.sin(frame * 0.02 + p.drift) * 0.15;
    p.x += Math.sin(p.drift) * 0.5 - (state === 'playing' ? scrollSpeed * 0.15 : 0.15);
    if (p.y > H + 10) { p.y = -10; p.x = Math.random() * W; }
    if (p.x < -10) p.x = W + 10;
    if (p.x > W + 10) p.x = -10;
  });

  if (state === 'select') {
    if (selNavCooldown > 0) selNavCooldown--;
    const left = keys['ArrowLeft'] || keys['KeyA'];
    const right = keys['ArrowRight'] || keys['KeyD'];
    if (selNavCooldown === 0 && (left || right)) {
      selCursor = (selCursor + (right ? 1 : -1) + CHARACTERS.length) % CHARACTERS.length;
      selNavCooldown = 14;
      sfxSelect();
    }
    bgOffset += 0.3;
    return;
  }

  if (state !== 'playing') { bgOffset += 0.3; return; }

  bgOffset += 0.3 + scrollSpeed * 0.6;

  spawnTimer--;
  if (spawnTimer <= 0) {
    spawnEnemy();
    // fewer enemies in early waves, ramping up steadily as waves climb
    spawnTimer = Math.max(28, 170 - wave * 13) + Math.random() * 40;
  }
  platformTimer--;
  if (platformTimer <= 0) {
    spawnPlatform();
    platformTimer = 160 + Math.random() * 90;
  }
  // no obstacles at all in the first couple of waves; frequency ramps up after that
  if (wave >= 2) {
    obstacleTimer--;
    if (obstacleTimer <= 0) {
      spawnObstacle();
      obstacleTimer = Math.max(50, 280 - wave * 22) + Math.random() * 60;
    }
  }

  if (score > 0 && score >= wave * 500) {
    wave++;
    scrollSpeed = Math.min(7.5, 1.6 + wave * 0.5);
    sfxLevelUp();
  }

  if (player.speedTimer > 0) player.speedTimer--;
  if (player.shieldTimer > 0) { player.shieldTimer--; player.invuln = Math.max(player.invuln, 2); }

  const moveSpeed = player.speedTimer > 0 ? 6.3 : 4.2;
  const slashCooldownMax = player.speedTimer > 0 ? 12 : 22;

  let moveInput = 0;
  if (keys['ArrowLeft'] || keys['KeyA']) moveInput = -1;
  if (keys['ArrowRight'] || keys['KeyD']) moveInput = 1;
  if (moveInput !== 0) player.facing = moveInput;
  player.vx = moveInput * moveSpeed;
  player.x += player.vx;
  player.x = Math.max(20, Math.min(W - 20 - player.w, player.x));

  const wantJump = keys['ArrowUp'] || keys['KeyW'] || keys['Space'];
  const jumpEdge = wantJump && !player.prevJumpKey;
  player.prevJumpKey = wantJump;
  if (player.onGround) player.jumpsUsed = 0;
  if (jumpEdge) {
    if (player.onGround) {
      player.vy = -12.5;
      player.onGround = false;
      player.jumpsUsed = 1;
      sfxJump();
    } else if (player.jumpsUsed < 2) {
      player.vy = -11;
      player.jumpsUsed = 2;
      sfxJump();
      spawnParticles(player.x + player.w / 2, player.y + 30, '#ffffff');
    }
  }
  applyGravityAndPlatforms(player);
  player.jumping = !player.onGround;

  if (player.slashCooldown > 0) player.slashCooldown--;
  if ((keys['KeyJ'] || keys['KeyF']) && player.slashCooldown === 0) {
    player.slashing = 14;
    player.slashCooldown = slashCooldownMax;
    sfxSlash();
  }
  if (player.slashing > 0) player.slashing--;

  if (player.invuln > 0) player.invuln--;
  if (player.hurtTimer > 0) player.hurtTimer--;

  const pcx = player.x + player.w / 2;
  const pcy = player.y + player.h / 2 - 10;

  const slashActive = player.slashing > 6 && player.slashing <= 13;
  const slashRange = 46;
  const slashX = pcx + player.facing * slashRange * 0.6;

  for (const pf of platforms) pf.x -= scrollSpeed;
  platforms = platforms.filter(pf => pf.x + pf.w > -60);

  for (const po of powerups) po.x -= scrollSpeed;
  powerups = powerups.filter(po => {
    const dx = Math.abs((po.x + po.w / 2) - pcx);
    const dy = Math.abs((po.y + po.h / 2) - pcy);
    if (dx < 28 && dy < 40) {
      collectPowerup(po.type);
      return false;
    }
    return po.x > -60;
  });

  for (const ob of obstacles) {
    ob.x -= scrollSpeed;
    const overlapX = player.x + player.w > ob.x && player.x < ob.x + ob.w;
    const tooLow = player.y > GROUND_Y - ob.h + 10;
    if (overlapX && tooLow && player.invuln === 0) {
      lives--;
      player.invuln = 90;
      player.hurtTimer = 20;
      shake = 12;
      sfxThud();
      player.vx = -player.facing * 5;
      player.x += player.vx;
      if (lives <= 0) endGame();
    }
  }
  obstacles = obstacles.filter(ob => ob.x + ob.w > -60);

  for (const en of enemies) {
    if (en.hitFlash > 0) en.hitFlash--;
    if (en.jumpCooldown > 0) en.jumpCooldown--;
    if (en.dead) {
      en.deathTimer++;
      en.y += 2.2;
      continue;
    }
    en.bob += 0.15;
    const toPlayer = pcx - (en.x + en.w / 2);
    en.dir = toPlayer > 0 ? 1 : -1;
    const enemySpeed = Math.abs(en.vx);
    en.x += en.dir * enemySpeed;
    en.x -= scrollSpeed * 0.5;

    let wantEnemyJump = false;
    if (en.onGround && en.jumpCooldown <= 0) {
      for (const ob of obstacles) {
        const ahead = (en.dir > 0) ? (ob.x - (en.x + en.w)) : ((en.x) - (ob.x + ob.w));
        if (ahead > 0 && ahead < 60) { wantEnemyJump = true; break; }
      }
      if (!wantEnemyJump) {
        for (const pf of platforms) {
          const ahead = (en.dir > 0) ? (pf.x - (en.x + en.w)) : ((en.x) - (pf.x + pf.w));
          const heightOk = pf.restY < en.y - 10 && pf.restY > en.y - 150;
          if (ahead > 0 && ahead < 50 && heightOk) { wantEnemyJump = true; break; }
        }
      }
    }
    if (wantEnemyJump) en.jumpCooldown = 55;
    updateVertical(en, wantEnemyJump, -11.5);

    const ecx = en.x + en.w / 2;
    const ecy = en.y + en.h / 2 - 10;

    if (slashActive) {
      const dx = ecx - slashX;
      const dy = ecy - pcy;
      if (Math.abs(dx) < 34 && Math.abs(dy) < 40) {
        en.dead = true;
        en.deathTimer = 0;
        score += 100;
        shake = 8;
        sfxDeathEnemy();
        spawnParticles(ecx, ecy, '#7a3548');
      }
    }

    if (!en.dead && player.invuln === 0) {
      const dx = Math.abs(ecx - pcx);
      const dy = Math.abs(ecy - pcy);
      if (dx < 26 && dy < 34) {
        lives--;
        player.invuln = 90;
        player.hurtTimer = 20;
        shake = 14;
        sfxHurt();
        player.vx = -en.dir * 6;
        player.x += player.vx;
        if (lives <= 0) endGame();
      }
    }
  }
  enemies = enemies.filter(en => {
    if (en.dead && en.deathTimer > 30) return false;
    if (!en.dead && (en.x < -80 || en.x > W + 80)) return false;
    return true;
  });

  particles.forEach(p => { p.x += p.vx; p.y += p.vy; p.vy += 0.3; p.life--; });
  particles = particles.filter(p => p.life > 0);
}

function collectPowerup(type) {
  sfxPowerup();
  shake = 4;
  const pcx = player.x + player.w / 2, pcy = player.y + player.h / 2 - 10;
  if (type === 'heart') {
    lives = Math.min(5, lives + 1);
    spawnParticles(pcx, pcy, '#ff6b8a');
  } else if (type === 'shield') {
    player.shieldTimer = 240;
    spawnParticles(pcx, pcy, '#7ad9ff');
  } else if (type === 'speed') {
    player.speedTimer = 300;
    spawnParticles(pcx, pcy, '#ffe066');
  }
}

function spawnParticles(x, y, color) {
  for (let i = 0; i < 10; i++) {
    particles.push({
      x, y,
      vx: (Math.random() - 0.5) * 6,
      vy: (Math.random() - 1.2) * 5,
      life: 24 + Math.random() * 12,
      color
    });
  }
}

function endGame() {
  state = 'gameover';
  hiScore = Math.max(hiScore, score);
  sfxGameOver();
}

// ---------- Drawing: background ----------
function drawTree(x, groundY, scale) {
  ctx.save();
  ctx.translate(x, groundY);
  ctx.scale(scale, scale);
  ctx.fillStyle = '#8a6247';
  ctx.fillRect(-8, -70, 16, 70);
  ctx.fillRect(-24, -40, 14, 10);
  ctx.fillRect(10, -46, 14, 10);
  const blossomColors = ['#ffd3e4', '#ffb7ce', '#ff9dc0'];
  const clusters = [
    [0, -100, 46], [-34, -80, 32], [32, -84, 32], [0, -60, 30], [-40, -110, 26], [40, -108, 26]
  ];
  clusters.forEach((c, i) => {
    ctx.fillStyle = blossomColors[i % blossomColors.length];
    ctx.beginPath();
    ctx.arc(c[0], c[1], c[2], 0, Math.PI * 2);
    ctx.fill();
  });
  ctx.restore();
}

function drawMountainRange(baseY, amp, parallax, count, color) {
  ctx.fillStyle = color;
  const offset = (bgOffset * parallax) % (W / count);
  ctx.beginPath();
  ctx.moveTo(-40, GROUND_Y + 6);
  for (let i = -1; i <= count + 1; i++) {
    const x = i * (W / count) - offset;
    const peak = baseY - amp * (0.5 + 0.5 * Math.sin(i * 1.7));
    ctx.lineTo(x, peak);
    ctx.lineTo(x + (W / count) / 2, baseY + 10);
  }
  ctx.lineTo(W + 40, GROUND_Y + 6);
  ctx.closePath();
  ctx.fill();
}

function drawBackground() {
  ctx.fillStyle = PAL.skyBot;
  ctx.fillRect(0, 0, W, H);

  const g = ctx.createLinearGradient(0, 0, 0, GROUND_Y + 20);
  g.addColorStop(0, PAL.skyTop);
  g.addColorStop(1, PAL.skyBot);
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, W, GROUND_Y + 20);

  const sunX = W - 130, sunY = 100, sunR = 50;
  const glow = ctx.createRadialGradient(sunX, sunY, 10, sunX, sunY, sunR * 2.4);
  glow.addColorStop(0, PAL.sunGlow);
  glow.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.fillStyle = glow;
  ctx.fillRect(sunX - sunR * 2.4, sunY - sunR * 2.4, sunR * 4.8, sunR * 4.8);
  ctx.fillStyle = PAL.sun;
  ctx.beginPath();
  ctx.arc(sunX, sunY, sunR, 0, Math.PI * 2);
  ctx.fill();

  drawMountainRange(GROUND_Y - 40, 65, 0.2, 8, PAL.mountainFar);
  bgTrees.filter(t => t.layer === 'far').forEach(t => {
    drawTree((t.xr * W - (bgOffset * 0.2) % W + W) % W, GROUND_Y - 30, t.scale * 0.6);
  });
  drawMountainRange(GROUND_Y - 10, 100, 0.5, 6, PAL.mountainNear);
  bgTrees.filter(t => t.layer === 'near').forEach(t => {
    drawTree((t.xr * W - (bgOffset * 0.5) % W + W) % W, GROUND_Y + 10, t.scale);
  });

  ctx.fillStyle = PAL.ground;
  ctx.fillRect(0, GROUND_Y + 10, W, H - GROUND_Y - 10);
  ctx.fillStyle = PAL.groundLine;
  ctx.fillRect(0, GROUND_Y + 46, W, 4);
  ctx.fillStyle = PAL.groundDirt;
  ctx.fillRect(0, GROUND_Y + 50, W, H - GROUND_Y - 50);

  ctx.fillStyle = 'rgba(210,120,150,0.25)';
  const tickOffset = (bgOffset * 2) % 40;
  for (let x = -40; x < W + 40; x += 40) {
    ctx.fillRect(x - tickOffset, GROUND_Y + 56, 20, 3);
  }
}

function drawPetals() {
  petals.forEach(p => {
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.drift * 2);
    ctx.fillStyle = p.color;
    ctx.beginPath();
    ctx.ellipse(0, 0, p.s, p.s * 0.6, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  });
}

function drawPlatforms() {
  platforms.forEach(pf => {
    const topY = pf.restY + 40;
    ctx.fillStyle = 'rgba(0,0,0,0.15)';
    ctx.fillRect(pf.x + 3, topY + 14, pf.w, 6);
    ctx.fillStyle = PAL.platform;
    ctx.fillRect(pf.x, topY, pf.w, 14);
    ctx.fillStyle = PAL.platformTop;
    ctx.fillRect(pf.x, topY, pf.w, 4);
    ctx.fillStyle = '#ffd3e4';
    ctx.fillRect(pf.x + pf.w * 0.25, topY - 3, 5, 3);
    ctx.fillRect(pf.x + pf.w * 0.65, topY - 3, 5, 3);
  });
}

// dojo training-dummy obstacle: wooden post, crossbeam arms, straw bundle
function drawObstacles() {
  obstacles.forEach(ob => {
    const baseY = GROUND_Y + 56;
    const postX = ob.x + ob.w / 2;
    ctx.fillStyle = 'rgba(0,0,0,0.15)';
    ctx.beginPath();
    ctx.ellipse(postX, baseY + 2, ob.w * 0.55, 4, 0, 0, Math.PI * 2);
    ctx.fill();

    // post
    ctx.fillStyle = PAL.dummyPost;
    ctx.fillRect(postX - 4, baseY - ob.h, 8, ob.h);

    // crossbeam arms
    ctx.fillStyle = PAL.dummyArm;
    ctx.fillRect(postX - 15, baseY - ob.h + 6, 30, 6);

    // straw-wrapped head/torso bundle
    ctx.fillStyle = PAL.dummyStraw;
    ctx.fillRect(postX - 9, baseY - ob.h - 10, 18, 16);
    ctx.fillStyle = PAL.dummyStrawDark;
    for (let i = 0; i < 4; i++) {
      ctx.fillRect(postX - 9, baseY - ob.h - 10 + i * 4, 18, 1.5);
    }
    // little straw wisps on top
    ctx.fillStyle = PAL.dummyStraw;
    ctx.fillRect(postX - 6, baseY - ob.h - 16, 3, 7);
    ctx.fillRect(postX, baseY - ob.h - 17, 3, 8);
    ctx.fillRect(postX + 5, baseY - ob.h - 15, 3, 7);
  });
}

function drawPowerupIcon(po) {
  const cx = po.x + po.w / 2, cy = po.y + po.h / 2;
  const bob = Math.sin(frame * 0.12 + po.x) * 3;
  ctx.save();
  ctx.translate(cx, cy + bob);
  const glowR = 16 + Math.sin(frame * 0.15) * 2;
  const glow = ctx.createRadialGradient(0, 0, 2, 0, 0, glowR);
  if (po.type === 'heart') { glow.addColorStop(0, 'rgba(255,107,138,0.5)'); }
  else if (po.type === 'shield') { glow.addColorStop(0, 'rgba(122,217,255,0.5)'); }
  else { glow.addColorStop(0, 'rgba(255,224,102,0.5)'); }
  glow.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.fillStyle = glow;
  ctx.fillRect(-glowR, -glowR, glowR * 2, glowR * 2);

  if (po.type === 'heart') {
    ctx.fillStyle = '#ff6b8a';
    ctx.beginPath();
    ctx.arc(-4, -3, 6, 0, Math.PI * 2);
    ctx.arc(4, -3, 6, 0, Math.PI * 2);
    ctx.moveTo(-9, 0);
    ctx.lineTo(0, 9);
    ctx.lineTo(9, 0);
    ctx.closePath();
    ctx.fill();
  } else if (po.type === 'shield') {
    ctx.fillStyle = '#7ad9ff';
    ctx.beginPath();
    ctx.moveTo(0, -9);
    ctx.lineTo(8, -5);
    ctx.lineTo(8, 4);
    ctx.lineTo(0, 10);
    ctx.lineTo(-8, 4);
    ctx.lineTo(-8, -5);
    ctx.closePath();
    ctx.fill();
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(-2, -5, 4, 11);
    ctx.fillRect(-5, -1, 10, 4);
  } else {
    ctx.fillStyle = '#ffe066';
    ctx.beginPath();
    ctx.moveTo(2, -10);
    ctx.lineTo(-6, 1);
    ctx.lineTo(-1, 1);
    ctx.lineTo(-3, 10);
    ctx.lineTo(7, -2);
    ctx.lineTo(1, -2);
    ctx.closePath();
    ctx.fill();
  }
  ctx.restore();
}

function drawPowerups() {
  powerups.forEach(drawPowerupIcon);
}

// ---------- Shared samurai sprite drawer (distinct silhouette per type) ----------
function drawCharacter(type, px, py, w, h, facing, pal, slashProgress, bounce, shadowY) {
  ctx.save();
  const cx = px + w / 2;
  const baseY = py - bounce;
  const shY = shadowY !== undefined ? shadowY : GROUND_Y + 48;

  ctx.translate(cx, 0);
  ctx.scale(facing, 1);
  ctx.translate(-cx, 0);

  ctx.fillStyle = 'rgba(0,0,0,0.2)';
  ctx.beginPath();
  ctx.ellipse(cx, shY, 18, 5, 0, 0, Math.PI * 2);
  ctx.fill();

  // legs
  ctx.fillStyle = pal.giDark;
  ctx.fillRect(px + 6, baseY + 36, 9, 22);
  ctx.fillRect(px + w - 15, baseY + 36, 9, 22);

  // gi torso
  ctx.fillStyle = pal.gi;
  ctx.fillRect(px + 4, baseY + 12, w - 8, 28);
  ctx.fillStyle = pal.giDark;
  ctx.fillRect(px + 4, baseY + 32, w - 8, 5);

  if (type === 'kabuto' || type === 'spear') {
    ctx.fillStyle = pal.accent;
    ctx.fillRect(px + 2, baseY + 12, w - 4, 7);
  }
  if (type === 'hood') {
    ctx.fillStyle = pal.accent;
    ctx.fillRect(px - 2, baseY + 8, 6, 34);
    ctx.fillRect(px + w - 4, baseY + 8, 6, 34);
  }

  // head
  ctx.fillStyle = pal.skin;
  ctx.fillRect(px + 8, baseY - 6, w - 16, 20);

  // head accessory per type
  if (type === 'kasa') {
    ctx.fillStyle = pal.hatDark;
    ctx.fillRect(px + 3, baseY - 9, w - 6, 4);
    ctx.fillStyle = pal.hatColor;
    ctx.beginPath();
    ctx.moveTo(px + 1, baseY - 9);
    ctx.lineTo(px + w - 1, baseY - 9);
    ctx.lineTo(px + w / 2, baseY - 26);
    ctx.closePath();
    ctx.fill();
  } else if (type === 'kabuto') {
    // rounded helmet dome
    ctx.fillStyle = pal.accent;
    ctx.beginPath();
    ctx.arc(px + w / 2, baseY - 4, (w - 10) / 2 + 3, Math.PI, 0, false);
    ctx.fill();
    ctx.fillRect(px + 5, baseY - 4, w - 10, 5);
    // neck guard flaps (shikoro) draping down the sides
    ctx.fillStyle = pal.accent;
    ctx.fillRect(px + 1, baseY - 3, 6, 13);
    ctx.fillRect(px + w - 7, baseY - 3, 6, 13);
    // crescent-moon maedate ornament on the brow
    ctx.strokeStyle = pal.accent2;
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(px + w / 2, baseY - 14, 6, Math.PI * 0.15, Math.PI * 0.95, false);
    ctx.stroke();
  } else if (type === 'dual') {
    ctx.fillStyle = pal.hair;
    ctx.fillRect(px + 9, baseY - 15, w - 18, 10);
    ctx.fillRect(px + w / 2 - 2, baseY - 21, 4, 8);
    ctx.fillRect(px + 6, baseY - 18, 5, 10);
    ctx.fillRect(px + w - 11, baseY - 18, 5, 10);
    ctx.fillStyle = pal.accent;
    ctx.fillRect(px + 8, baseY - 3, w - 16, 4);
  } else if (type === 'spear') {
    ctx.fillStyle = pal.hair;
    ctx.fillRect(px + 10, baseY - 12, w - 20, 8);
    ctx.fillStyle = pal.accent;
    ctx.fillRect(px + w / 2 - 2, baseY - 18, 4, 7);
  } else if (type === 'hood') {
    // draped cowl swept back, covering crown and trailing behind
    ctx.fillStyle = pal.accent;
    ctx.beginPath();
    ctx.moveTo(px + 5, baseY - 2);
    ctx.quadraticCurveTo(px + w / 2 - 4, baseY - 24, px + w - 2, baseY - 6);
    ctx.quadraticCurveTo(px + w + 6, baseY - 2, px + w - 3, baseY + 4);
    ctx.lineTo(px + 6, baseY + 2);
    ctx.closePath();
    ctx.fill();
    // face wrap across the lower face
    ctx.fillStyle = pal.accent;
    ctx.fillRect(px + 7, baseY + 5, w - 14, 6);
    // eyes peeking between hood and wrap
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(px + w - 15, baseY, 6, 3);
    if (pal.accent2) {
      // hanging drape tail
      ctx.fillStyle = pal.accent2;
      ctx.fillRect(px + w - 6, baseY - 1, 4, 18);
    }
  }

  // weapon
  ctx.fillStyle = pal.skin;
  if (slashProgress !== null && slashProgress !== undefined) {
    if (type === 'dual' || type === 'hood') {
      const bladeLen = type === 'hood' ? 18 : 28;
      const bladeCol = type === 'hood' ? '#d8d8de' : PAL.bladeColor;
      [0.35, -0.15].forEach((off, i) => {
        const ang = -0.9 + slashProgress * 2.2 + off;
        ctx.save();
        ctx.translate(px + w - 6, baseY + 22 - i * 8);
        ctx.rotate(ang);
        ctx.fillStyle = pal.skin;
        ctx.fillRect(-4, -3, 8, 8);
        ctx.fillStyle = bladeCol;
        ctx.fillRect(4, -2, bladeLen, 4);
        ctx.restore();
      });
    } else if (type === 'spear') {
      const ang = -0.35 + slashProgress * 0.7;
      const thrust = Math.sin(slashProgress * Math.PI) * 10;
      ctx.save();
      ctx.translate(px + w - 6 + thrust, baseY + 22);
      ctx.rotate(ang);
      ctx.fillStyle = pal.skin;
      ctx.fillRect(-4, -4, 10, 10);
      ctx.fillStyle = '#5a4030';
      ctx.fillRect(6, -2, 46, 4);
      ctx.fillStyle = PAL.bladeColor;
      ctx.fillRect(50, -3, 14, 6);
      ctx.restore();
    } else {
      const ang = -0.9 + slashProgress * 2.2;
      ctx.save();
      ctx.translate(px + w - 6, baseY + 22);
      ctx.rotate(ang);
      ctx.fillRect(-4, -4, 10, 10);
      ctx.fillStyle = PAL.bladeColor;
      ctx.fillRect(6, -3, 42, 5);
      ctx.fillStyle = '#8a5a2b';
      ctx.fillRect(-2, -3, 8, 5);
      ctx.restore();
    }
  } else {
    ctx.fillRect(px + w - 10, baseY + 18, 10, 10);
    if (type === 'dual') {
      ctx.fillStyle = pal.giDark;
      ctx.fillRect(px + 1, baseY + 26, 5, 12);
      ctx.fillRect(px + w - 6, baseY + 26, 5, 12);
    } else if (type === 'spear') {
      ctx.save();
      ctx.translate(px + 4, baseY + 24);
      ctx.rotate(-0.55);
      ctx.fillStyle = '#5a4030';
      ctx.fillRect(-3, -34, 6, 62);
      ctx.fillStyle = PAL.bladeColor;
      ctx.fillRect(-3, -42, 6, 10);
      ctx.restore();
    } else if (type === 'hood') {
      ctx.fillStyle = '#8a8a92';
      ctx.fillRect(px + 2, baseY + 28, 6, 6);
      ctx.fillRect(px + w - 8, baseY + 28, 6, 6);
    } else {
      ctx.fillStyle = '#5a4030';
      ctx.save();
      ctx.translate(px + 2, baseY + 20);
      ctx.rotate(-0.5);
      ctx.fillRect(-3, -20, 6, 40);
      ctx.restore();
    }
  }
  ctx.restore();
}

function drawPlayer() {
  const flash = (player.invuln > 0 && Math.floor(player.invuln / 4) % 2 === 0);
  ctx.save();
  if (flash) ctx.globalAlpha = 0.4;
  const bounce = player.onGround ? Math.sin(frame * 0.3) * (Math.abs(player.vx) > 0.1 ? 1.5 : 0) : 0;
  const slashProgress = player.slashing > 0 ? (14 - player.slashing) / 14 : null;
  const pal = CHARACTERS[selCursor];
  drawCharacter(pal.type, player.x, player.y, player.w, player.h, player.facing, pal, slashProgress, bounce);
  if (player.shieldTimer > 0) {
    ctx.globalAlpha = 0.35 + Math.sin(frame * 0.3) * 0.15;
    ctx.strokeStyle = '#7ad9ff';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.ellipse(player.x + player.w / 2, player.y + 24, 30, 40, 0, 0, Math.PI * 2);
    ctx.stroke();
  }
  ctx.restore();
}

// ---------- Rival samurai enemy ----------
const ENEMY_PAL = { gi: '#5a2a38', giDark: '#33161f', skin: '#d9b592', hair: '#141014', headband: '#c0435f', eye: '#ff4d6a', blade: '#dcdce2' };

function drawEnemy(en) {
  ctx.save();
  const alpha = en.dead ? Math.max(0, 1 - en.deathTimer / 30) : 1;
  ctx.globalAlpha = alpha;
  if (en.hitFlash > 0) ctx.filter = 'brightness(1.6)';

  const cx = en.x + en.w / 2;
  const bob = en.dead ? 0 : Math.sin(en.bob) * 2;
  const y = en.y - Math.abs(bob);
  const rot = en.dead ? (en.deathTimer / 30) * (Math.PI / 2) * en.dir : 0;

  ctx.translate(cx, GROUND_Y + 10);
  ctx.rotate(rot);
  ctx.translate(-cx, -(GROUND_Y + 10));
  ctx.translate(cx, 0);
  ctx.scale(en.dir, 1);
  ctx.translate(-cx, 0);

  ctx.fillStyle = 'rgba(0,0,0,0.2)';
  ctx.beginPath();
  ctx.ellipse(cx, GROUND_Y + 48, 16, 5, 0, 0, Math.PI * 2);
  ctx.fill();

  // legs
  ctx.fillStyle = ENEMY_PAL.giDark;
  ctx.fillRect(en.x + 5, y + 34, 8, 20);
  ctx.fillRect(en.x + en.w - 13, y + 34, 8, 20);

  // gi torso + belt
  ctx.fillStyle = ENEMY_PAL.gi;
  ctx.fillRect(en.x + 3, y + 10, en.w - 6, 26);
  ctx.fillStyle = ENEMY_PAL.giDark;
  ctx.fillRect(en.x + 3, y + 28, en.w - 6, 4);

  // head
  ctx.fillStyle = ENEMY_PAL.skin;
  ctx.fillRect(en.x + 6, y - 6, en.w - 12, 18);
  // topknot hair
  ctx.fillStyle = ENEMY_PAL.hair;
  ctx.fillRect(en.x + 7, y - 11, en.w - 14, 6);
  ctx.fillRect(en.x + en.w / 2 - 2, y - 16, 4, 6);
  // headband (rival colors, flowing ends)
  ctx.fillStyle = ENEMY_PAL.headband;
  ctx.fillRect(en.x + 6, y - 1, en.w - 12, 3);
  ctx.fillRect(en.x + en.w - 6, y, 8, 3);
  // glowing eye
  ctx.fillStyle = ENEMY_PAL.eye;
  ctx.fillRect(en.x + en.w - 11, y + 1, 5, 3);

  // katana at hip, held ready
  ctx.fillStyle = ENEMY_PAL.skin;
  ctx.fillRect(en.x + en.w - 8, y + 16, 8, 8);
  ctx.save();
  ctx.translate(en.x + en.w - 4, y + 20);
  ctx.rotate(0.5 + Math.sin(en.bob) * 0.05);
  ctx.fillStyle = ENEMY_PAL.blade;
  ctx.fillRect(0, -2, 26, 4);
  ctx.fillStyle = '#3a2418';
  ctx.fillRect(-6, -2, 7, 4);
  ctx.restore();

  ctx.restore();
  ctx.filter = 'none';
}

function drawParticles() {
  particles.forEach(p => {
    ctx.globalAlpha = Math.max(0, p.life / 30);
    ctx.fillStyle = p.color;
    ctx.fillRect(p.x - 2, p.y - 2, 4, 4);
  });
  ctx.globalAlpha = 1;
}

function drawHUD() {
  ctx.save();
  function shadowText(text, x, y, size = 20, color = PAL.hudText) {
    ctx.font = `bold ${size}px "Courier New", monospace`;
    ctx.fillStyle = PAL.hudShadow;
    ctx.fillText(text, x + 2, y + 2);
    ctx.fillStyle = color;
    ctx.fillText(text, x, y);
  }
  ctx.textBaseline = 'top';
  shadowText(`SCORE ${String(score).padStart(5, '0')}`, 16, 14);
  shadowText(`WAVE ${wave}`, W - 130, 14, 20, '#b5548a');

  for (let i = 0; i < lives; i++) {
    ctx.fillStyle = PAL.hudShadow;
    ctx.fillRect(16 + i * 26 + 2, 46, 18, 5);
    ctx.fillStyle = PAL.bladeColor;
    ctx.strokeStyle = '#c9457a';
    ctx.lineWidth = 1;
    ctx.fillRect(16 + i * 26, 44, 18, 5);
    ctx.strokeRect(16 + i * 26, 44, 18, 5);
  }

  let buffY = 66;
  if (player.speedTimer > 0) { shadowText('⚡ SPEED', 16, buffY, 13, '#c9a015'); buffY += 16; }
  if (player.shieldTimer > 0) { shadowText('◆ SHIELD', 16, buffY, 13, '#3a9ac9'); buffY += 16; }
  ctx.restore();
}

function drawSelectScreen() {
  ctx.fillStyle = 'rgba(255,240,246,0.55)';
  ctx.fillRect(0, 0, W, H);
  ctx.textAlign = 'center';

  ctx.font = 'bold 30px "Courier New", monospace';
  ctx.fillStyle = '#ffffff';
  ctx.fillText('CHOOSE YOUR RONIN', W / 2 + 2, 44 + 2);
  ctx.fillStyle = '#c9457a';
  ctx.fillText('CHOOSE YOUR RONIN', W / 2, 44);

  const boxCount = CHARACTERS.length;
  const boxW = 118, boxH = 160, gap = 14;
  const totalW = boxCount * boxW + (boxCount - 1) * gap;
  const startX = W / 2 - totalW / 2;
  const boxY = 90;

  CHARACTERS.forEach((c, i) => {
    const bx = startX + i * (boxW + gap);
    const selected = i === selCursor;
    ctx.fillStyle = selected ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.55)';
    ctx.fillRect(bx, boxY, boxW, boxH);
    ctx.lineWidth = selected ? 4 : 2;
    ctx.strokeStyle = selected ? '#e8709e' : '#f2c6d8';
    ctx.strokeRect(bx, boxY, boxW, boxH);

    const spriteBounce = selected ? Math.sin(frame * 0.15) * 2 : 0;
    const thumbPy = boxY + 66;
    ctx.save();
    ctx.beginPath();
    ctx.rect(bx + 2, boxY + 2, boxW - 4, boxH - 4);
    ctx.clip();
    drawCharacter(c.type, bx + boxW / 2 - 17, thumbPy, 34, 58, 1, c, null, spriteBounce, thumbPy + 48);
    ctx.restore();

    if (selected) {
      ctx.font = 'bold 16px "Courier New", monospace';
      ctx.fillStyle = '#e8709e';
      ctx.fillText('▲', bx + boxW / 2, boxY - 18);
    }
  });

  const blink = Math.floor(frame / 30) % 2 === 0;
  if (blink) {
    ctx.font = 'bold 15px "Courier New", monospace';
    ctx.fillStyle = '#e8709e';
    ctx.fillText('◄ ► TO CHOOSE   •   ENTER / TAP TO BEGIN', W / 2, boxY + boxH + 34);
  }
  ctx.textAlign = 'left';
}

function drawGameOverScreen() {
  ctx.fillStyle = 'rgba(255,240,246,0.7)';
  ctx.fillRect(0, 0, W, H);
  ctx.textAlign = 'center';
  ctx.font = 'bold 40px "Courier New", monospace';
  ctx.fillStyle = '#ffffff';
  ctx.fillText('YOU HAVE FALLEN', W / 2 + 3, H / 2 - 47);
  ctx.fillStyle = '#c9457a';
  ctx.fillText('YOU HAVE FALLEN', W / 2, H / 2 - 50);

  ctx.font = 'bold 18px "Courier New", monospace';
  ctx.fillStyle = '#8a2a54';
  ctx.fillText(`FINAL SCORE ${score}   HI-SCORE ${hiScore}`, W / 2, H / 2);

  const blink = Math.floor(frame / 30) % 2 === 0;
  if (blink) {
    ctx.font = 'bold 14px "Courier New", monospace';
    ctx.fillStyle = '#e8709e';
    ctx.fillText('PRESS ENTER / TAP TO CHOOSE AGAIN', W / 2, H / 2 + 40);
  }
  ctx.textAlign = 'left';
}

function draw() {
  ctx.save();
  if (shake > 0) {
    ctx.translate((Math.random() - 0.5) * shake, (Math.random() - 0.5) * shake);
  }
  drawBackground();
  if (state === 'playing' || state === 'gameover') {
    drawPlatforms();
    drawObstacles();
    drawPowerups();
    enemies.forEach(drawEnemy);
    drawPlayer();
    drawParticles();
  }
  drawPetals();
  ctx.restore();

  if (state === 'playing') {
    drawHUD();
  } else if (state === 'select') {
    drawSelectScreen();
  } else if (state === 'gameover') {
    drawHUD();
    drawGameOverScreen();
  }
}

function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}
loop();
})();
</script>
